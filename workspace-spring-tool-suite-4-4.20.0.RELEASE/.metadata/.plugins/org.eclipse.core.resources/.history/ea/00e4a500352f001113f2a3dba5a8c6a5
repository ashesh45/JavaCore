package Abstraction;

public class Abstraction {

	
	
	/* Abstarction
	 * 
	 * process of hiding implementation details
	 * TO achieve abstraction
	 * 
	 * 1 Abstract class:
	 *  class which contains abstract methods and non abstract methods
	 *   abstacct methods
	 *   
	 *   methods which do not have body
	 *    syntax:
	 *    
	 *    abstract return_type method_name9arg1 , arg2,...)
	 *    
	 *    abstract void add();
	 *    
	 *    #every abstract class must have at least one child class and child class must overide abstract method
	 *    
	 *    
	 *    we cannot create object of abstract class
	 *    level of abstraction
	 *    
	 *    #syntax
	 *    
	 *    abstract class class-name{
	 *    
	 *   //abstract method
	 *   
	 *   //non abstract method
	 *   }
	 *  
	 * 
	 * 
	 * 2.Interface:
	 * 
	 * 
	 *   #same as class which contains public abstract method and public static final variable only
	 *   
	 *   every interface must have at least one implementation class and impl. class must overide abstract method
	 *   
	 *   #we cannot create object
	 *   100% abstraction
	 *   
	 *   we can inherit multiple interfaces at a time.
	 *   
	 *   
	 *   syntax
	 *   
	 *   interface interface_name{
	 *   
	 *   //public abstract methods
	 *   }
	 *   
	 *   
	 *   
	 * 
	 * 
	 * 
	 * 
	 * 
	 */
}
