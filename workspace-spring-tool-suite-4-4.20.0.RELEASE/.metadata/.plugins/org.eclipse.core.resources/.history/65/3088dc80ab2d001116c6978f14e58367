	        double max = Double.MIN_VALUE;
	        double min = Double.MAX_VALUE;

	        for (Employee e : employee) {
	            if (e != null) {   // null safety
	                double salary = e.getSalary();

	                max = Math.max(max, salary);
	                min = Math.min(min, salary);
	            }
	        }

